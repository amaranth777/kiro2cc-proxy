# kiro-rs 服务器环境变量配置
# 复制为 .env 并修改

# 必填
API_KEY=sk-kiro-rs-your-key

# 可选
# ADMIN_API_KEY=sk-admin-your-key
# PORT=8990
# HOST=0.0.0.0  # 警告：设为 0.0.0.0 会监听所有网络接口，请确保有防火墙保护
# REGION=us-east-1
# AUTH_REGION=us-east-1
# API_REGION=us-east-1
# PROXY_URL=http://127.0.0.1:7890
# PROXY_USERNAME=
# PROXY_PASSWORD=
# LOAD_BALANCING_MODE=priority
# KIRO_LOG_DIR=/var/log/kiro-rs
